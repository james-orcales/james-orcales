background          = 000
theme               = Rose Pine
font-size           = 16
font-family         = Iosevka
font-feature        = -calt,-liga,dlig
window-height       = 9999
window-width        = 9999
macos-option-as-alt = true

keybind = ctrl+left=esc:b
keybind = ctrl+right=esc:f
keybind = ctrl+tab=ignore
keybind = ctrl+equal=increase_font_size:4
keybind = ctrl+-=decrease_font_size:4
